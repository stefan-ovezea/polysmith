{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CAD Core Commands",
  "type": "object",
  "required": ["id", "type"],
  "properties": {
    "id": { "type": "string" },
    "type": {
      "type": "string",
      "enum": [
        "ping",
        "shutdown",
        "create_document",
        "get_document_state",
        "get_session_state",
        "get_viewport_state",
        "export_document",
        "export_document_stl",
        "save_document",
        "load_document",
        "project_face_into_sketch",
        "add_box_feature",
        "add_cylinder_feature",
        "update_box_feature",
        "update_extrude_depth",
        "rename_feature",
        "delete_feature",
        "undo",
        "redo",
        "select_feature",
        "select_reference",
        "select_face",
        "start_sketch_on_plane",
        "start_sketch_on_face",
        "set_sketch_tool",
        "update_sketch_line",
        "update_sketch_point",
        "set_sketch_line_constraint",
        "set_sketch_equal_length_constraint",
        "set_sketch_perpendicular_constraint",
        "set_sketch_parallel_constraint",
        "set_sketch_coincident_constraint",
        "set_sketch_point_fixed",
        "update_sketch_circle",
        "update_sketch_dimension",
        "add_sketch_line",
        "add_sketch_rectangle",
        "add_sketch_circle",
        "select_sketch_point",
        "select_sketch_entity",
        "select_sketch_dimension",
        "select_sketch_profile",
        "extrude_profile",
        "finish_sketch",
        "reenter_sketch",
        "clear_selection"
      ]
    },
    "payload": { "type": "object" }
  },
  "additionalProperties": false
}
